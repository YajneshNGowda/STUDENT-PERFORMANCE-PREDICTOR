# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default - no setup needed)
DATABASE_URL=sqlite:///./eduguard.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/eduguard

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Token expiry in minutes (default 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Initial Admin ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@eduguard.edu
ADMIN_PASSWORD=Admin@123

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Use * for development only.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Email Alerts (SendGrid) ───────────────────────────────────────────────────
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxx
# FROM_EMAIL=alerts@yourschool.edu

# ── SMS Alerts (Twilio) ───────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
# TWILIO_PHONE_FROM=+1234567890
